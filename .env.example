# Google Gemini (used by most analyzers)
GEMINI_API_KEY=your_gemini_api_key_here

# Parent/child stance script uses GOOGLE_API_KEY (same key often works)
GOOGLE_API_KEY=your_gemini_api_key_here

# Reddit scraper (reddit_scraper_rebuilt.py)
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_client_secret
REDDIT_USER_AGENT=RedditScraper/1.0 by u/your_reddit_username
